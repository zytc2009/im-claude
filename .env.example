# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Telegram（设为 false 可单独关闭，不影响微信）
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=

# DingTalk 企业内部应用机器人
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
# 签名验证 (outgoing webhook 安全设置里的签名密钥)
DINGTALK_WEBHOOK_SECRET=
# 钉钉回调服务器端口
DINGTALK_WEBHOOK_PORT=3000

# 访问控制: 逗号分隔的用户ID白名单，留空=允许所有人
ALLOWED_USER_IDS=

# Claude Code 允许使用的工具，建议生产环境不开 Bash
ALLOWED_TOOLS=Read,Glob,Grep,Write

# Claude Code 工作目录
WORKING_DIR=/workspace

# Whisper 语音识别模型（tiny/base/small/medium/large，越大越准但越慢）
# 需要先安装 Whisper：pip install openai-whisper
WHISPER_MODEL=base

# Clawra 自拍功能（可选）
# 前往 https://fal.ai/ 注册账号并充值（最低 $10），在控制台获取 API Key
# 未配置时自拍功能不可用，启动时会打印警告
FAL_KEY=

# 微信 iLink ClawBot（设为 true 启用，设为 false 关闭，首次启动需扫码登录）
WECHAT_ENABLED=false
